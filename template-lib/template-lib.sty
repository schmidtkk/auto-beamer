% ============================================================================
% template-lib.sty — Template Library Master Entry
% ============================================================================
% Three-tier system: Theme + Layout + Component
%
% USAGE:
%   \usepackage[<theme>]{template-lib}
%   Available themes: academic, teal, dark, navygold, minimal
%
%   Then load layouts as needed:
%   \uselayout{text}    % or 1img, 2img, 3img, eq, table, imgtop, twocol
%
%   Components auto-loaded: title, block, fig
% ============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{template-lib}[2026/05/23 Beamer Template Library]

% ── Required Packages ───────────────────────────────────────────────────────
\RequirePackage{etoolbox}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins,breakable}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{booktabs}
\RequirePackage{array}
\RequirePackage{colortbl}
\RequirePackage{multirow}
\RequirePackage{adjustbox}
\RequirePackage{pifont}
\RequirePackage{tikz}
\RequirePackage{amsmath,amssymb}
\usetikzlibrary{positioning,calc}

% ── Path Resolution ─────────────────────────────────────────────────────────
% Since this .sty is loaded as \usepackage[...]{template-lib/template-lib},
% all \input paths inside it resolve relative to the main document directory.
% So we hardcode the prefix to point into the template-lib/ subdirectory.
\newcommand{\TLlibpath}{template-lib/}

% ── Theme Selection (via package option) ────────────────────────────────────
% Default = Slate Coral (graphite + coral) on the Moloch chrome. The legacy
% palettes (academic, teal, …) remain available; existing decks that pass an
% explicit theme are unaffected.
\newcommand{\TLthemepath}{theme-slatecoral}

% Chrome (title-bar style) is ORTHOGONAL to the colour palette.
%   auto       — global default (Metropolis filled bar) unless a theme opts in
%   moloch     — de-filled title: primary text + accent rule (Metropolis fork look)
%   metropolis — force the classic filled bar
% A theme file may upgrade `auto` → its preferred chrome; an explicit
% [moloch]/[metropolis] option always wins.
\newcommand{\TLchrome}{auto}
\newif\ifTLdark   % dark themes set \TLdarktrue before \input'ing theme-base

% Legacy palettes
\DeclareOption{academic}{\renewcommand{\TLthemepath}{theme-academic}}
\DeclareOption{teal}{\renewcommand{\TLthemepath}{theme-teal}}
\DeclareOption{dark}{\renewcommand{\TLthemepath}{theme-dark}}
\DeclareOption{navygold}{\renewcommand{\TLthemepath}{theme-navygold}}
\DeclareOption{minimal}{\renewcommand{\TLthemepath}{theme-minimal}}
% New light palettes
\DeclareOption{slatecoral}{\renewcommand{\TLthemepath}{theme-slatecoral}}
\DeclareOption{plum}{\renewcommand{\TLthemepath}{theme-plum}}
\DeclareOption{claret}{\renewcommand{\TLthemepath}{theme-claret}}
\DeclareOption{terracotta}{\renewcommand{\TLthemepath}{theme-terracotta}}
\DeclareOption{forestbrass}{\renewcommand{\TLthemepath}{theme-forestbrass}}
% New dark palettes
\DeclareOption{rosepine}{\renewcommand{\TLthemepath}{theme-rosepine}}
\DeclareOption{catppuccin}{\renewcommand{\TLthemepath}{theme-catppuccin}}
\DeclareOption{midnightamber}{\renewcommand{\TLthemepath}{theme-midnightamber}}
% Chrome switches
\DeclareOption{moloch}{\renewcommand{\TLchrome}{moloch}}
\DeclareOption{metropolis}{\renewcommand{\TLchrome}{metropolis}}

\ProcessOptions\relax

% ── Load Selected Theme ─────────────────────────────────────────────────────
\input{\TLlibpath themes/\TLthemepath.sty}

% ── Component Registration ──────────────────────────────────────────────────
\input{\TLlibpath components/comp-title.sty}
\input{\TLlibpath components/comp-block.sty}
\input{\TLlibpath components/comp-fig.sty}
\input{\TLlibpath components/comp-exercise.sty}

% ── Layout Registration System ─────────────────────────────────────────────-
\newcommand{\uselayout}[1]{%
  \input{\TLlibpath layouts/layout-#1.sty}%
}

% ── Quick Layout Aliases (use \uselayout{name} instead) ────────────────────
% Removed: aliases conflicted with command names defined inside layout files.
% Use \uselayout{text}, \uselayout{1img}, etc. directly.

% ── CJK Support (cross-platform, user-overridable) ──────────────────────────
\input{\TLlibpath font-config.sty}

% ── Math Fonts ──────────────────────────────────────────────────────────────
% KpMath (Kepler) — designed for math typography, heavier serif than Latin Modern.
% Pairs well with both Computer Modern body text and Source Han Serif SC CJK.
% Available weights: Regular, Bold, Light, SemiBold, Sans, SansBold.
\RequirePackage{unicode-math}
\setmathfont{KpMath-Regular.otf}[BoldFont=KpMath-Bold.otf]

% ── Global Settings ─────────────────────────────────────────────────────────
\setbeamertemplate{navigation symbols}{}
\graphicspath{{slides_assets/}}
