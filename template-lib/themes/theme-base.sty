% ============================================================================
% theme-base.sty — Shared Beamer Boilerplate for All Themes
% ============================================================================
% Loaded by each theme file AFTER the 11 TL color tokens are defined.
% Themes must also define two semantic aliases before \input'ing this file:
%
%   \definecolor{TLcanvas}{named}{white}       % or TLsurface for dark
%   \definecolor{TLblockbody}{named}{white}     % or TLsurface for dark
%
% This file provides:
%   - Metropolis base theme loading
%   - Beamer color wiring (references TL tokens + TLcanvas/TLblockbody)
%   - Font settings
%   - Footer template + \TLfootleft / \TLsetfoot
%   - \TLtitlebg / \TLresetbg hooks
% ============================================================================

\usetheme[progressbar=frametitle,block=fill,numbering=fraction]{metropolis}
\usepackage{appendixnumberbeamer}

% ── Beamer Color Wiring ─────────────────────────────────────────────────────
\setbeamercolor{background canvas}{bg=TLcanvas}
\setbeamercolor{normal text}{fg=TLink,bg=TLcanvas}
\setbeamercolor{frametitle}{bg=TLprimary,fg=white}
\setbeamercolor{frametitle right}{bg=TLprimaryDark}
\setbeamercolor{title separator}{fg=TLaccent}
\setbeamercolor{progress bar}{fg=TLaccent,bg=TLprimaryLight}
\setbeamercolor{alerted text}{fg=TLaccent}
\setbeamercolor{block title}{bg=TLprimaryTint,fg=TLprimary}
\setbeamercolor{block body}{bg=TLsurface}
\setbeamercolor{block title alerted}{bg=TLaccentLight,fg=TLaccent}
\setbeamercolor{block body alerted}{bg=TLblockbody}
\setbeamercolor{block title example}{bg=TLprimaryLight,fg=TLprimaryDark}
\setbeamercolor{block body example}{bg=TLblockbody}
\setbeamercolor{palette primary}{fg=white,bg=TLprimary}
\setbeamercolor{itemize item}{fg=TLprimary}
\setbeamercolor{itemize subitem}{fg=TLprimary}
\setbeamercolor{enumerate item}{fg=TLprimary}
\setbeamercolor{enumerate subitem}{fg=TLprimary}

% ── Chrome Resolution (title-bar style × light/dark) ────────────────────────
% \TLchrome (auto|moloch|metropolis) and \ifTLdark are set in template-lib.sty
% and (for dark) by the theme file before this \input. The wiring above is the
% LIGHT + METROPOLIS default (filled primary title bar); the branches below
% adjust it for the moloch chrome and/or dark palettes.
\providecommand{\TLchrome}{auto}
\def\TLchrome@moloch{moloch}
% Title-page secondary text + table-header text. Defaults suit LIGHT themes
% (where TLprimary is dark / the title canvas is dark); the dark branch flips
% them so they stay legible when TLprimary is a LIGHT colour.
\colorlet{TLtitlesub}{TLprimaryLight}   % subtitle / author / date on title slide
\colorlet{TLtheadfg}{white}             % \TLthead text on a TLprimary header row
% Result/Warn block fills. Light default mixes the status colour into white;
% the dark branch mixes it into the dark surface so the (light) body text stays
% readable instead of sitting on a near-white box.
\colorlet{TLposfill}{TLpos!10}
\colorlet{TLnegfill}{TLneg!8}
\ifTLdark
  % ---- DARK chrome ----
  \ifx\TLchrome\TLchrome@moloch
    \setbeamercolor{frametitle}{bg=TLsurface,fg=TLprimary}
    \setbeamercolor{frametitle right}{bg=TLsurface}
    \setbeamercolor{palette primary}{fg=TLinkSoft,bg=TLsurface}
  \else
    \setbeamercolor{frametitle}{bg=TLprimaryLight,fg=TLprimary}
    \setbeamercolor{frametitle right}{bg=TLprimaryTint}
    \setbeamercolor{palette primary}{fg=TLink,bg=TLprimaryLight}
  \fi
  \setbeamercolor{block body alerted}{bg=TLsurface}
  \setbeamercolor{block body example}{bg=TLsurface}
  % Dark: primary is light, title canvas is dark → flip the helper text colours.
  \colorlet{TLtitlesub}{TLinkSoft}   % legible secondary text on the dark title canvas
  \colorlet{TLtheadfg}{TLsurface}    % dark text on the light-primary header row
  \colorlet{TLposfill}{TLpos!22!TLsurface}  % subtle status tint over the dark surface
  \colorlet{TLnegfill}{TLneg!18!TLsurface}
  % Example block: light fg so it stays legible on the dark title band.
  \setbeamercolor{block title example}{bg=TLprimaryLight,fg=TLpos}
  % \def (not \renewcommand): these macros are \providecommand'd later in this
  % file, so defining them here makes that later \providecommand a no-op.
  \def\TLtitlebg{\setbeamercolor{background canvas}{bg=TLprimaryTint}}
  \def\TLresetbg{\setbeamercolor{background canvas}{bg=TLsurface}}
\else
  % ---- LIGHT chrome ----
  \ifx\TLchrome\TLchrome@moloch
    % Moloch: de-fill the title bar (primary text on canvas + accent progress rule),
    % lighten the footer to a subtle tinted band.
    \setbeamercolor{frametitle}{bg=TLcanvas,fg=TLprimary}
    \setbeamercolor{frametitle right}{bg=TLcanvas}
    \setbeamercolor{palette primary}{fg=TLinkSoft,bg=TLprimaryTint}
  \fi
  % (metropolis/auto light keeps the filled bar already wired above)
\fi

% ── Fonts ───────────────────────────────────────────────────────────────────
\setbeamerfont{frametitle}{size=\Large,series=\bfseries}
\setbeamerfont{framesubtitle}{size=\normalsize}
\setbeamerfont{block title}{size=\normalsize,series=\bfseries}
\setbeamerfont{block body}{size=\small}

% ── Footer ──────────────────────────────────────────────────────────────────
\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{footline}{%
  \leavevmode%
  \hbox{%
    \begin{beamercolorbox}[wd=0.72\paperwidth,ht=2.5ex,dp=1.25ex,leftskip=8pt]{palette primary}%
      \usebeamerfont{footline}\tiny \TLfootleft%
    \end{beamercolorbox}%
    \begin{beamercolorbox}[wd=0.28\paperwidth,ht=2.5ex,dp=1.25ex,rightskip=8pt]{palette primary}%
      \hfill\usebeamerfont{footline}\tiny\insertframenumber\,/\,\inserttotalframenumber%
    \end{beamercolorbox}%
  }%
}

% ── User-configurable footer text ───────────────────────────────────────────
\newcommand{\TLfootleft}{Presentation}
\newcommand{\TLsetfoot}[1]{\renewcommand{\TLfootleft}{#1}}

% ── Title Page / Background Hooks ───────────────────────────────────────────
% These use \providecommand so themes can override the canvas color.
\providecommand{\TLtitlebg}{%
  \setbeamercolor{background canvas}{bg=TLprimaryDark}%
}
\providecommand{\TLresetbg}{%
  \setbeamercolor{background canvas}{bg=TLcanvas}%
}
