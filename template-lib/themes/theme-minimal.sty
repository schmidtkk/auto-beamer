% ============================================================================
% theme-minimal.sty — Minimal Theme (Charcoal + Silver)
% ============================================================================
% High-contrast grayscale palette for distraction-free presentations.
% ============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{theme-minimal}[2026/05/23 Minimal Beamer Theme]

% ── Color Palette ───────────────────────────────────────────────────────────
\definecolor{TLprimary}{HTML}{2d2d2d}      % Charcoal — primary brand
\definecolor{TLprimaryDark}{HTML}{1a1a1a}  % Near black — title bg
\definecolor{TLprimaryLight}{HTML}{d4d4d4} % Light gray — accents
\definecolor{TLprimaryTint}{HTML}{f0f0f0}  % Very light gray — block bg
\definecolor{TLaccent}{HTML}{6b6b6b}       % Mid gray — emphasis
\definecolor{TLaccentLight}{HTML}{e8e8e8}  % Light gray — highlight bg
\definecolor{TLink}{HTML}{111111}           % Near black — body text
\definecolor{TLinkSoft}{HTML}{888888}       % Silver — secondary text
\definecolor{TLsurface}{HTML}{fafafa}       % Off-white — canvas bg
\definecolor{TLpos}{HTML}{3a7d44}           % Muted green
\definecolor{TLneg}{HTML}{b33a3a}           % Muted red

% ── Semantic Aliases (light theme: canvas = white) ──────────────────────────
\definecolor{TLcanvas}{named}{white}
\definecolor{TLblockbody}{named}{white}

% ── Shared Boilerplate ──────────────────────────────────────────────────────
\input{template-lib/themes/theme-base.sty}

% ── Theme-specific Footer ───────────────────────────────────────────────────
\renewcommand{\TLfootleft}{Minimal Presentation}
