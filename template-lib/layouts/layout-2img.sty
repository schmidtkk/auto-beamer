% ============================================================================
% layout-2img.sty — Two Image Layouts
% ============================================================================
% Side-by-side comparison or related pair.
% Usage: \TLtwoimg{img1}{cap1}{img2}{cap2}{bottom-text}
% ============================================================================

% ── Two Images Side by Side (equal width) ───────────────────────────────────
\providecommand{\TLtwoimg}[5][0.48]{%
  % #1 = image width fraction (default 0.48)
  % #2 = image 1
  % #3 = caption 1
  % #4 = image 2
  % #5 = caption 2
  \begin{columns}[T]
    \begin{column}{#1\textwidth}
      \centering
      \adjincludegraphics[max width=\linewidth,max height=0.50\textheight]{#2}
      \\[3pt]
      \footnotesize\color{TLinkSoft} #3
    \end{column}
    \begin{column}{\dimexpr\textwidth-#1\textwidth-#1\textwidth-0.02\textwidth\relax}
    \end{column}
    \begin{column}{#1\textwidth}
      \centering
      \adjincludegraphics[max width=\linewidth,max height=0.50\textheight]{#4}
      \\[3pt]
      \footnotesize\color{TLinkSoft} #5
    \end{column}
  \end{columns}
}

% ── Two Images + Bottom Text Block ──────────────────────────────────────────
\providecommand{\TLtwoimgbottom}[6][0.48]{%
  % #1 = image width
  % #2-5 = images and captions
  % #6 = bottom text
  \TLtwoimg[#1]{#2}{#3}{#4}{#5}
  \vspace{0.5em}
  \begin{minipage}{\textwidth}
    #6
  \end{minipage}
}

% ── Two Images with Labels (A/B or Before/After) ────────────────────────────
\providecommand{\TLtwolabeled}[6][0.48]{%
  % #1 = image width
  % #2 = label 1 (e.g., \textbf{(a)})
  % #3 = image 1
  % #4 = label 2
  % #5 = image 2
  % #6 = caption
  \begin{columns}[T]
    \begin{column}{#1\textwidth}
      \centering
      #2\\[2pt]
      \adjincludegraphics[max width=\linewidth,max height=0.48\textheight]{#3}
    \end{column}
    \begin{column}{\dimexpr\textwidth-#1\textwidth-#1\textwidth-0.02\textwidth\relax}
    \end{column}
    \begin{column}{#1\textwidth}
      \centering
      #4\\[2pt]
      \adjincludegraphics[max width=\linewidth,max height=0.48\textheight]{#5}
    \end{column}
  \end{columns}
  \vspace{0.3em}
  \centering\footnotesize\color{TLinkSoft} #6
}
