% ============================================================================
% comp-block.sty — Content Block Components
% ============================================================================
% Reusable info/alert/result blocks.
% Usage: \TLinfoblock{title}{content} or \TLalertblock{content}
% ============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{comp-block}[2026/05/23 Block Components]

\RequirePackage{tikz}
\RequirePackage{pifont}

% ── Info Block (primary color) ──────────────────────────────────────────────
\providecommand{\TLinfoblock}[2]{%
  \begin{tikzpicture}
    \node[draw=TLprimary, fill=TLprimaryTint, text=TLink, rounded corners=3pt,
          inner sep=8pt, text width=\linewidth-16pt, align=justify] {%
      \small\textbf{\color{TLprimary}#1}\\[0.3em]
      #2%
    };
  \end{tikzpicture}%
}

% ── Alert Block (accent color) ──────────────────────────────────────────────
\providecommand{\TLalertblock}[2][]{%
  \begin{tikzpicture}
    \node[draw=TLaccent, fill=TLaccentLight, text=TLink, rounded corners=3pt,
          inner sep=8pt, text width=\linewidth-16pt, align=justify] {%
      \small\textbf{\color{TLaccent}#1}\\[0.3em]
      #2%
    };
  \end{tikzpicture}%
}

% ── Result Block (green) ────────────────────────────────────────────────────
\providecommand{\TLresultblock}[2]{%
  \begin{tikzpicture}
    \node[draw=TLpos, fill=TLposfill, text=TLink, rounded corners=3pt,
          inner sep=8pt, text width=\linewidth-16pt, align=justify] {%
      \small\textbf{\color{TLpos}#1}\\[0.3em]
      #2%
    };
  \end{tikzpicture}%
}

% ── Warning Block (red) ─────────────────────────────────────────────────────
\providecommand{\TLwarnblock}[2]{%
  \begin{tikzpicture}
    \node[draw=TLneg, fill=TLnegfill, text=TLink, rounded corners=3pt,
          inner sep=8pt, text width=\linewidth-16pt, align=justify] {%
      \small\textbf{\color{TLneg}#1}\\[0.3em]
      #2%
    };
  \end{tikzpicture}%
}

% ── Key Takeaway (lightweight inline) ───────────────────────────────────────
\providecommand{\TLtakeaway}[1]{%
  \vspace{0.4em}%
  \begin{tikzpicture}
    \node[fill=TLaccentLight, text=TLink, rounded corners=3pt, inner sep=8pt,
          text width=\linewidth-16pt, align=justify] {%
      \small\textcolor{TLaccent}{\textbf{Key Takeaway.}} #1%
    };
  \end{tikzpicture}%
  \vspace{0.2em}%
}

% ── Inline Term Highlight ───────────────────────────────────────────────────
\providecommand{\TLterm}[1]{\textcolor{TLaccent}{\textbf{#1}}}

% ── Semantic Inline Commands ────────────────────────────────────────────────
% Inspired by Noi1r/beamer-skill's \pos{}/\con{}/\HL{} pattern.
% TL-prefixed versions for consistency with our naming convention.

% Positive/emphasized inline text (green)
\providecommand{\TLpos}[1]{\textcolor{TLpos}{\textbf{#1}}}

% Negative/contrast inline text (red)
\providecommand{\TLneg}[1]{\textcolor{TLneg}{\textbf{#1}}}

% Highlight inline text (accent color + light background)
\providecommand{\TLhl}[1]{\colorbox{TLaccentLight}{\textcolor{TLaccent}{\textbf{#1}}}}

% Neutral/muted inline text (secondary gray)
\providecommand{\TLmuted}[1]{\textcolor{TLinkSoft}{#1}}

% ── Check/X marks ───────────────────────────────────────────────────────────
\providecommand{\TLyes}{\textcolor{TLpos}{\ding{51}}}
\providecommand{\TLno}{\textcolor{TLneg}{\ding{55}}}
\providecommand{\TLdeltaup}[1]{\textcolor{TLpos}{\textbf{+#1}}}
\providecommand{\TLdeltadown}[1]{\textcolor{TLneg}{\textbf{-#1}}}
