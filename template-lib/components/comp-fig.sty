% ============================================================================
% comp-fig.sty — Figure/Table Helper Components
% ============================================================================
% Auto-scaling images, subfigures, and table styling.
% ============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{comp-fig}[2026/05/23 Figure Components]

\RequirePackage{graphicx}
\RequirePackage{adjustbox}
\RequirePackage{booktabs}

% ── Auto-scale Image (fit column, cap height) ───────────────────────────────
\providecommand{\TLautoimg}[2][]{%
  \centering\adjincludegraphics[max width=\linewidth,max height=0.72\textheight,#1]{#2}%
}

% ── Image with Caption Below ────────────────────────────────────────────────
\providecommand{\TLimgcap}[3][]{%
  \centering
  \adjincludegraphics[max width=\linewidth,max height=0.65\textheight,#1]{#2}
  \\[3pt]
  \footnotesize\color{TLinkSoft} #3
}

% ── Side-by-side Images with Labels ─────────────────────────────────────────
\providecommand{\TLsubfig}[4][0.48]{%
  % #1 = width fraction
  % #2 = image 1
  % #3 = image 2
  % #4 = main caption
  \begin{columns}[c]
    \begin{column}{#1\textwidth}
      \centering
      \adjincludegraphics[max width=\linewidth,max height=0.50\textheight]{#2}
    \end{column}
    \begin{column}{#1\textwidth}
      \centering
      \adjincludegraphics[max width=\linewidth,max height=0.50\textheight]{#3}
    \end{column}
  \end{columns}
  \vspace{0.3em}
  \centering\footnotesize\color{TLinkSoft} #4
}

% ── Styled Table Header Row ─────────────────────────────────────────────────
\providecommand{\TLthead}{\rowcolor{TLprimary}\color{white}}

% ── Table Row Highlight ─────────────────────────────────────────────────────
\providecommand{\TLthl}{\rowcolor{TLprimaryTint}}

% ── Full-width Table Wrapper ────────────────────────────────────────────────
\makeatletter
\@ifundefined{TLtable}{%
\newenvironment{TLtable}[1]{%
  \vspace{0.3em}
  \begin{center}
    \small
    \begin{tabular}{#1}
}{%
    \end{tabular}
  \end{center}
  \vspace{0.2em}
}%
}{}
\makeatother
